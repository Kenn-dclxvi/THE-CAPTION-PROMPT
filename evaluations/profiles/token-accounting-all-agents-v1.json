{
  "accounting": {
    "revision": "v1",
    "scope": "all_agents",
    "source": "codex_rollout_final_usage_by_workspace"
  },
  "aggregation": {
    "case": "sum final total_tokens across root and all descendant sessions",
    "iteration": "sum all case total_tokens",
    "prompt_set_result": "median of iteration total_tokens"
  },
  "evidence": {
    "breakdown_path": "layer2/extensions/<run_id>/all-agent-usage/usage.json",
    "kpi_input": "EVAL_USAGE_FILE.total_tokens",
    "required_fields": [
      "root_thread_id",
      "root_total_tokens",
      "all_agent_total_tokens",
      "session_count",
      "sessions"
    ]
  },
  "inclusion": {
    "cached_input_tokens": true,
    "descendant_depth": "recursive",
    "root_agent": true,
    "subagents": true
  },
  "missing_usage_policy": {
    "action": "exclude_and_repeat_same_slot",
    "reason_code": "codex_all_agent_usage_incomplete",
    "token_estimation": "forbidden"
  },
  "profile_id": "token-accounting-all-agents-v1",
  "result_contract": {
    "comparison_view_schema": "the-caption-prompt.prompt-set-comparison-view/v2",
    "legacy_root_only_result_schema": "the-caption-prompt.prompt-set-result/v1",
    "prompt_set_result_schema": "the-caption-prompt.prompt-set-result/v2"
  },
  "schema_version": "the-caption-prompt.token-accounting-profile/v1"
}
